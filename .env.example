# Legacy bootstrap (optional): if set together with TG_CHAT_ID, one account is auto-registered on first start
MAX_TOKEN=
MAX_DEVICE_ID=

# Telegram bot token (required)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_ADMIN_ID=123456789

# Optional: legacy auto-bootstrap chat/user id
TG_CHAT_ID=123456789

# SQLite path for account bindings
DB_PATH=data/max2tg.sqlite3

# Debug mode: подробные логи + дамп JSON в debug/ (true/false)
DEBUG=false

# Разрешить ответы из Telegram в Max (true/false)
REPLY_ENABLED=false
